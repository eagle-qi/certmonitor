# ===========================================
# CertMonitor 环境配置文件
# ===========================================

# 应用配置
APP_NAME=certmonitor
APP_ENV=development
APP_PORT=8080
APP_SECRET=your-secret-key-change-in-production

# MySQL 数据库配置
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=CertMonitor@2024
MYSQL_DATABASE=certmonitor
MYSQL_CHARSET=utf8mb4

# Redis 缓存配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 认证配置
JWT_SECRET=jwt-secret-key-change-in-production
JWT_EXPIRE_HOURS=24

# 日志配置
LOG_LEVEL=debug
LOG_PATH=/var/log/certmonitor

# 邮件配置 (用于验证码和告警通知)
MAIL_SMTP_HOST=smtp.example.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=noreply@example.com
MAIL_SMTP_PASS=your-smtp-password
MAIL_FROM_NAME=CertMonitor

# 短信配置 (用于告警通知)
SMS_PROVIDER=dummy
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=CertMonitor
SMS_TEMPLATE_CODE=

# SSO 单点登录配置
SSO_ENABLED=false
SSO_PROVIDER=oidc
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=http://localhost:8080/api/v1/auth/sso/callback
SSO_AUTH_URL=
SSO_TOKEN_URL=
SSO_USERINFO_URL=

# 备案查询接口配置 (公网探测用)
ICP_API_KEY=
ICP_API_URL=https://api.example.com/icp/query

# 文件存储配置
STORAGE_TYPE=local
STORAGE_PATH=/data/certmonitor/uploads
MAX_UPLOAD_SIZE=10485760

# 探测引擎配置 (Python)
CRAWLER_API_HOST=crawler
CRAWLER_API_PORT=8000

# 前端配置
FRONTEND_URL=http://localhost:5173
